<!-- <!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>Meta2d 10万节点 FPS 监控压测</title>
    <style>
      body,
      html {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #f8f9fa;
      }
      #app {
        width: 100%;
        height: 100%;
      }
      #panel {
        position: absolute;
        top: 15px;
        left: 15px;
        z-index: 999;
        background: white;
        padding: 15px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        font-family: sans-serif;
      }
      .status-box {
        margin-top: 10px;
        font-size: 14px;
        font-weight: bold;
        color: #d93025;
        white-space: pre-wrap;
        line-height: 1.6;
      }
      #fps-meter {
        color: #07c160;
        font-size: 18px;
        margin-bottom: 5px;
      }
    </style>
    <script type="importmap">
      { "imports": { "@meta2d/core": "https://esm.sh/@meta2d/core@1.0.47" } }
    </script>
  </head>
  <body>
    <div id="panel">
      <div id="fps-meter">FPS: --</div>
      <button onclick="runTest(1000)">1千</button>
      <button onclick="runTest(50000)">5万</button>
      <button
        onclick="runTest(100000)"
        style="border-color: red; color: red"
      >
        10万极限
      </button>
      <div
        id="status"
        class="status-box"
      >
        准备就绪
      </div>
    </div>
    <div id="app"></div>

    <script type="module">
      import { Meta2d } from "@meta2d/core";
      const meta2d = new Meta2d("app", { rule: false, grid: false });
      const statusEl = document.getElementById("status");
      const fpsEl = document.getElementById("fps-meter");

      // --- FPS 监控逻辑 ---
      let frameCount = 0;
      let lastTime = performance.now();
      let fps = 0;

      function updateFPS() {
        const now = performance.now();
        frameCount++;
        if (now - lastTime >= 1000) {
          fps = Math.round((frameCount * 1000) / (now - lastTime));
          fpsEl.innerText = `FPS: ${fps}`;
          frameCount = 0;
          lastTime = now;
        }
        requestAnimationFrame(updateFPS);
      }
      updateFPS(); // 启动循环

      // --- 压测逻辑 ---
      window.runTest = (count) => {
        statusEl.innerText = `正在渲染 ${count} 个节点...`;
        setTimeout(() => {
          const start = performance.now();
          const pens = [];
          const size = 20;
          const cols = Math.ceil(Math.sqrt(count));

          for (let i = 0; i < count; i++) {
            pens.push({
              id: "p" + i,
              name: "rectangle",
              x: (i % cols) * (size + 5),
              y: Math.floor(i / cols) * (size + 5),
              width: size,
              height: size,
              fillStyle: "#e6a23c",
              strokeStyle: "#333"
            });
          }

          meta2d.clear();
          meta2d.open({ pens });
          meta2d.fitView();

          const end = performance.now();
          statusEl.innerText = `渲染完成 (${count}节点)\n耗时: ${(
            end - start
          ).toFixed(2)}ms`;
        }, 50);
      };
    </script>
  </body>
</html> -->
